# Generated code (regen via api/scripts/gen-all.sh)
services/*/generated/
web-client/src/api/types.ts
openapitools.json

# Java
target/
*.class
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Node / frontend
node_modules/
dist/
.vite/
.eslintcache
coverage/

# IDEs
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
infra/.env

# Local k8s deploy secrets (never commit)
infra/k8s/.env

# Terraform (state can contain secrets; .terraform/ is local provider cache)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
# terraform.tfvars is committed on purpose (non-secret defaults); ignore local
# secret overrides instead.
*.auto.tfvars
override.tf
override.tf.json

# Ansible
infra/ansible/*.retry
