# Copy to infra/.env and adjust (infra/.env is gitignored).
POSTGRES_USER=tso
POSTGRES_PASSWORD=tso
POSTGRES_DB=tso
POSTGRES_PORT=5432

# JWT Configuration
# Generate a secure random key (min 32 chars) for production
JWT_SECRET=your-secret-key-min-32-chars-change-in-production
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# GenAI (Logos — team key from tutor; off-campus requires eduVPN)
LOGOS_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
# LLM_BASE_URL=https://logos.aet.cit.tum.de/v1

# Chat → GenAI (docker-compose sets this automatically; override for local dev)
# GENAI_BASE_URL=http://localhost:8084

# Grafana (observability dashboard)
# GRAFANA_PORT defaults to 3001 to avoid colliding with apps on 3000.
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
