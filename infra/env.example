# Copy to infra/.env and adjust (infra/.env is gitignored).
POSTGRES_USER=tso
POSTGRES_PASSWORD=tso
POSTGRES_DB=tso
POSTGRES_PORT=5432

# JWT Configuration
# Generate a secure random key (min 32 chars) for production
JWT_SECRET=your-secret-key-min-32-chars-change-in-production
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# Grafana (observability dashboard)
# GRAFANA_PORT defaults to 3001 to avoid colliding with apps on 3000.
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
