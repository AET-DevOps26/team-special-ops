# Managed by Ansible — do not edit on the VM. Rendered from templates/env.j2 with
# non-secret vars from group_vars/all.yml and secrets from the environment.
# Consumed by docker-compose.yml + docker-compose.azure.yml on the VM.

# --- Postgres ---
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

# --- Auth ---
JWT_SECRET={{ jwt_secret }}

# --- GenAI / LLM ---
LOGOS_API_KEY={{ logos_api_key }}
LLM_MODEL={{ llm_model }}
LLM_BASE_URL={{ llm_base_url }}

# --- Azure overlay (Traefik TLS + GHCR images) ---
DOMAIN={{ domain }}
IMAGE_TAG={{ image_tag }}
LETSENCRYPT_EMAIL={{ letsencrypt_email }}
