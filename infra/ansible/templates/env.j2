# Managed by Ansible (infra/ansible/templates/env.j2) — do not edit by hand.
# Rendered to {{ app_dir }}/.env and consumed by docker compose on the VM.

# --- Postgres ---
POSTGRES_USER={{ postgres_user }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_PASSWORD={{ lookup('env', 'POSTGRES_PASSWORD') }}

# --- App secrets ---
JWT_SECRET={{ lookup('env', 'JWT_SECRET') }}
LOGOS_API_KEY={{ lookup('env', 'LOGOS_API_KEY') | default('', true) }}

# --- GenAI / LLM ---
LLM_MODEL={{ llm_model }}
LLM_BASE_URL={{ llm_base_url }}

# --- Deployment / routing ---
DOMAIN={{ domain }}
# Browser origin the Spring services accept CORS from — the public HTTPS host.
APP_CORS_ALLOWED_ORIGINS=https://{{ domain }}
IMAGE_TAG={{ image_tag }}
IMAGE_REGISTRY={{ image_registry }}
LETSENCRYPT_EMAIL={{ letsencrypt_email }}
