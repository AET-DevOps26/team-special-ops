# Let's Encrypt production ACME issuer, cluster-wide. The chart's Ingress
# references it by name via the cert-manager.io/cluster-issuer annotation; on
# deploy cert-manager solves the HTTP-01 challenge through ingress-nginx and
# installs/renews the TLS cert automatically.
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cluster_issuer_name }}
spec:
  acme:
    server: https://acme-v02.api.letsencrypt.org/directory
    email: {{ letsencrypt_email }}
    privateKeySecretRef:
      name: {{ cluster_issuer_name }}-account-key
    solvers:
      - http01:
          ingress:
            class: nginx
